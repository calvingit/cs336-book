---
// src/components/HillClimb.astro
// 蒙眼下山：可视化梯度下降。滑块 = 学习率，点一步走一步，检测震荡与到达谷底。
// props:
//   start - 机器人起点 x（viewBox 0~400），bottom - 谷底 x
const { start = 60, bottom = 210 } = Astro.props;
const cfg = JSON.stringify({ start, bottom });
---
<div class="hc" data-hc data-cfg={cfg}>
  <svg class="hc-svg" viewBox="0 0 400 200"></svg>
  <div class="hc-ctrl">
    <button class="hc-step">👣 往低处走一步</button>
    <button class="hc-reset">重来</button>
    <span class="hc-lr-label">步子大小</span>
    <input class="hc-lr" type="range" min="1" max="40" value="12" />
  </div>
  <div class="hc-msg"></div>
</div>

<script>
  document.querySelectorAll('[data-hc]').forEach((box) => {
    const { start, bottom } = JSON.parse(box.getAttribute('data-cfg'));
    const svg   = box.querySelector('.hc-svg');
    const msg   = box.querySelector('.hc-msg');
    const lrEl  = box.querySelector('.hc-lr');
    const Y = (x) => 0.0016 * (x - bottom) * (x - bottom) + 40;
    const slope = (x) => 2 * 0.0016 * (x - bottom);
    let x = start, steps = 0, lastDist = Infinity;

    const draw = () => {
      let path = 'M0,' + Y(0);
      for (let px = 0; px <= 400; px += 4) path += ' L' + px + ',' + Y(px);
      const by = Y(x);
      svg.innerHTML =
        `<path d="${path} L400,200 L0,200 Z" fill="#eaf3ff"/>` +
        `<path d="${path}" fill="none" stroke="#b8d0f0" stroke-width="2"/>` +
        `<circle cx="${x}" cy="${by - 8}" r="9" fill="#ff7a4d"/>` +
        `<text x="${x}" y="${by - 4}" font-size="11" text-anchor="middle" fill="#fff">🤖</text>`;
    };

    const step = () => {
      const lr = +lrEl.value;
      x = x - slope(x) * lr * 3;
      x = Math.max(5, Math.min(395, x));
      steps++;
      const dist = Math.abs(x - bottom);
      if (dist < 6) {
        msg.textContent = `🎉 到谷底啦！用了 ${steps} 步。机器人"练好了"——错误降到最低！`;
      } else if (dist > lastDist + 2) {
        msg.textContent = `😵 步子太大啦！机器人一下跨过头，在山谷两边来回蹦。把「步子大小」调小一点试试。`;
      } else {
        msg.textContent = `第 ${steps} 步：往低处挪了一点，错误变小了，离谷底更近了。`;
      }
      lastDist = dist;
      draw();
    };

    box.querySelector('.hc-step').addEventListener('click', step);
    box.querySelector('.hc-reset').addEventListener('click', () => {
      x = start; steps = 0; lastDist = Infinity; msg.textContent = '点「往低处走一步」，看机器人怎么滑到谷底。'; draw();
    });
    draw();
    msg.textContent = '点「往低处走一步」，看机器人怎么一步步滑到谷底。';
  });
</script>

<style>
  .hc { max-width: 600px; margin: 1.2rem auto; padding: 20px;
    background: linear-gradient(135deg,#eef6ff,#f0fff6); border: 2px solid #cfe4ff; border-radius: 18px; }
  .hc-svg { width: 100%; background: #fff; border-radius: 12px; display: block; }
  .hc-ctrl { display: flex; align-items: center; gap: 12px; margin-top: 12px; flex-wrap: wrap; }
  .hc-step { padding: 8px 18px; font-size: 14px; font-weight: 700; color: #fff;
    background: #3f8cff; border: none; border-radius: 8px; cursor: pointer; }
  .hc-reset { padding: 8px 14px; font-size: 13px; color: #3f8cff; background: #fff;
    border: 2px solid #cfe4ff; border-radius: 8px; cursor: pointer; }
  .hc-lr-label { font-size: 12px; color: #5a7fa9; }
  .hc-lr { flex: 1; min-width: 100px; }
  .hc-msg { margin-top: 10px; font-size: 13px; color: #2f6fc9; font-weight: 600; min-height: 20px; }
</style>
