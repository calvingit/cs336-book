---
// 分词积木：输入一句话，实时切成彩色 token 块
---
<div class="tok-app">
  <input class="tok-input" type="text" value="今天天气真好呀" aria-label="输入一句话" />
  <div class="tok-hint">切出来的积木 👇</div>
  <div class="tok-out"></div>
  <div class="tok-count"></div>
</div>
<script>
  const COLORS = ['#ffd6e7','#ffe9c7','#d6f0ff','#d9ffe0','#e8d6ff','#ffe0d6','#d6fff4'];
  document.querySelectorAll('.tok-app').forEach((app) => {
    const input = app.querySelector('.tok-input');
    const out   = app.querySelector('.tok-out');
    const count = app.querySelector('.tok-count');
    const render = () => {
      out.innerHTML = '';
      const chars = Array.from(input.value).filter((c) => c.trim() !== '');
      chars.forEach((ch, i) => {
        const b = document.createElement('span');
        b.className = 'tok-block'; b.textContent = ch;
        b.style.background = COLORS[i % COLORS.length];
        out.appendChild(b);
      });
      count.textContent = `一共切出 ${chars.length} 块积木！`;
    };
    input.addEventListener('input', render);
    render();
  });
</script>
<style>
  .tok-app { max-width: 560px; margin: 1.2rem auto; padding: 20px; background: linear-gradient(135deg,#fef6ff,#eef4ff); border: 2px solid #ffe0f0; border-radius: 18px; }
  .tok-input { width: 100%; box-sizing: border-box; padding: 12px 14px; font-size: 16px; border: 2px solid #d9b8ee; border-radius: 12px; outline: none; }
  .tok-hint { margin: 12px 0 6px; font-size: 12px; color: #9a7fb0; }
  .tok-out { display: flex; flex-wrap: wrap; gap: 6px; min-height: 44px; padding: 12px; background: #fff; border-radius: 12px; border: 1px dashed #e0c8f0; }
  .tok-block { display: inline-block; padding: 8px 12px; font-size: 18px; border-radius: 10px; box-shadow: 0 2px 0 rgba(0,0,0,0.08); }
  .tok-count { margin-top: 10px; font-size: 13px; color: #7a3fb0; font-weight: 600; }
</style>
