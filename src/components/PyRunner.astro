---
const { code = '' } = Astro.props;
---
<div class="pyrun" data-pyrun>
  <textarea class="pyrun-code" spellcheck="false">{code}</textarea>
  <div class="pyrun-bar">
    <button class="pyrun-go">▶ 运行</button>
    <span class="pyrun-status"></span>
  </div>
  <pre class="pyrun-out" aria-live="polite"></pre>
</div>
<script>
  let pyReady = null;
  function loadPyodide_() {
    if (pyReady) return pyReady;
    pyReady = new Promise((resolve) => {
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/pyodide/v0.26.2/full/pyodide.js';
      s.onload = async () => resolve(await window.loadPyodide());
      document.head.appendChild(s);
    });
    return pyReady;
  }
  document.querySelectorAll('[data-pyrun]').forEach((box) => {
    const codeEl = box.querySelector('.pyrun-code');
    const goBtn  = box.querySelector('.pyrun-go');
    const status = box.querySelector('.pyrun-status');
    const out    = box.querySelector('.pyrun-out');
    goBtn.addEventListener('click', async () => {
      goBtn.disabled = true;
      status.textContent = '第一次运行要下载小引擎，请稍等…';
      try {
        const py = await loadPyodide_();
        status.textContent = '运行中…';
        py.runPython('import sys, io\nsys.stdout = io.StringIO()');
        py.runPython(codeEl.value);
        out.textContent = py.runPython('sys.stdout.getvalue()');
        status.textContent = '✅ 完成';
      } catch (e) {
        out.textContent = '出错啦：' + e; status.textContent = '❌';
      } finally { goBtn.disabled = false; }
    });
  });
</script>
<style>
  .pyrun { margin: 1.2rem 0; border: 2px solid #d6e4ff; border-radius: 14px; overflow: hidden; }
  .pyrun-code { width: 100%; box-sizing: border-box; min-height: 120px; padding: 14px; font-family: ui-monospace, Menlo, monospace; font-size: 14px; border: none; outline: none; background: #0f1424; color: #e6edf3; resize: vertical; }
  .pyrun-bar { display: flex; align-items: center; gap: 12px; padding: 8px 12px; background: #eef4ff; }
  .pyrun-go { padding: 6px 18px; font-size: 14px; font-weight: 700; color: #fff; background: #5b8cff; border: none; border-radius: 8px; cursor: pointer; }
  .pyrun-go:disabled { opacity: .5; cursor: not-allowed; }
  .pyrun-status { font-size: 12px; color: #6a7a9a; }
  .pyrun-out { margin: 0; padding: 12px 14px; min-height: 20px; background: #fff; font-family: ui-monospace, monospace; font-size: 13px; white-space: pre-wrap; color: #333; }
</style>
